{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PulseGuard",
  "version": "0.1.0",
  "identifier": "com.toyofumi.pulseguard",
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "security": {
      "csp": null
    },
    "windows": [
      {
        "label": "main",
        "title": "PulseGuard",
        "width": 1440,
        "height": 960,
        "minWidth": 1180,
        "minHeight": 760,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "category": "Utility",
    "copyright": "Copyright (c) 2026 toyofumi",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/256x256.png"
    ],
    "linux": {
      "deb": {
        "depends": [
          "libwebkit2gtk-4.1-0",
          "libgtk-3-0",
          "libayatana-appindicator3-1"
        ]
      }
    },
    "longDescription": "PulseGuard is a lightweight per-process monitor for Ubuntu and other Linux desktops. It collects CPU, memory, disk I/O and internet I/O activity into SQLite and renders a native-feeling dashboard with Tauri.",
    "shortDescription": "Lightweight per-process Linux monitor with SQLite history",
    "targets": [
      "deb",
      "appimage"
    ]
  }
}

